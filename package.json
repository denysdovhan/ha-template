{
  "name": "ha-template",
  "version": "1.4.1",
  "description": "A tiny (<2kB) lit component for rendering templates in Home Assistant custom cards",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "start": "rollup -c --watch",
    "build": "rollup -c",
    "size": "size-limit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write . --ignore-path .gitignore",
    "test": "npm run lint && npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "home-assistant",
    "homeassistant",
    "template",
    "component",
    "custom-cards",
    "lovelace",
    "lit"
  ],
  "author": {
    "name": "Denys Dovhan",
    "email": "denysdovhan@gmail.com",
    "url": "http://denysdovhan.com/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/denysdovhan/ha-template.git"
  },
  "license": "MIT",
  "files": [
    "dist"
  ],
  "dependencies": {
    "custom-card-helpers": "^2.0.0"
  },
  "peerDependencies": {
    "lit": "^2.0.0 || ^3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/plugin-transform-runtime": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-babel": "^6.1.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@semantic-release/git": "^10.0.1",
    "@size-limit/preset-small-lib": "^11.0.2",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "^3.7.4",
    "rollup": "^4.59.0",
    "rollup-plugin-minify-html-literals-v3": "^1.3.4",
    "rollup-plugin-typescript2": "^0.36.0",
    "semantic-release": "^25.0.3",
    "size-limit": "^12.0.0",
    "typescript": "^5.9.3"
  },
  "browserslist": [
    "last 2 versions",
    "not dead"
  ],
  "lint-staged": {
    "*.js": "eslint --fix",
    "*": "prettier --write --ignore-unknown"
  },
  "prettier": {
    "singleQuote": true
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github",
      "@semantic-release/git"
    ]
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "2kB"
    }
  ]
}
